#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    clock_t start = clock();

    int rows, cols;
    printf("Enter number of rows: ");
    scanf("%d", &rows);
    printf("Enter number of columns: ");
    scanf("%d", &cols);

    int N = rows * cols;

    int *arr = (int *)malloc(N * sizeof(int));
    srand((unsigned)time(NULL));

    FILE *fin = fopen("input.txt", "w");
    for (int i = 0; i < N; i++) {
        arr[i] = rand() % 100 + 1;
        fprintf(fin, "%d", arr[i]);
        if (i < N - 1) fprintf(fin, " ");
    }
    fclose(fin);

    free(arr);

    fin = fopen("input.txt", "r");

    int *nums = (int *)malloc(N * sizeof(int));
    int count = 0;
    while (count < N && fscanf(fin, "%d", &nums[count]) == 1) {
        count++;
    }
    fclose(fin);

    FILE *fout = fopen("output.txt", "w");

    for (int i = 0; i < count; i++) {
        if (nums[i] % 5 == 0 && nums[i] % 7 == 0) {
            fprintf(fout, "FIVESEVEN");
        } else if (nums[i] % 5 == 0) {
            fprintf(fout, "FIVE");
        } else if (nums[i] % 7 == 0) {
            fprintf(fout, "SEVEN");
        } else {
            fprintf(fout, "%d", nums[i]);
        }
        if (i < count - 1) fprintf(fout, " ");
    }
    fprintf(fout, "\n");
    fclose(fout);

    printf("Result saved to output.txt\n");

    int **matrix = (int **)malloc(rows * sizeof(int *));
    for (int i = 0; i < rows; i++) {
        matrix[i] = (int *)malloc(cols * sizeof(int));
    }

    int idx = 0;
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            matrix[i][j] = nums[idx++];
        }
    }

    int *rowSums = (int *)calloc(rows, sizeof(int));
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            rowSums[i] += matrix[i][j];
        }
    }

    int *colSums = (int *)calloc(cols, sizeof(int));
    for (int j = 0; j < cols; j++) {
        for (int i = 0; i < rows; i++) {
            colSums[j] += matrix[i][j];
        }
    }

    printf("\nMatrix:\n");
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            printf("%d ", matrix[i][j]);
        }
        printf("| Row sum: %d\n", rowSums[i]);
    }

    printf("Column sums: ");
    for (int j = 0; j < cols; j++) {
        printf("%d ", colSums[j]);
    }
    printf("\n");

    for (int i = 0; i < rows; i++) free(matrix[i]);
    free(matrix);
    free(rowSums);
    free(colSums);
    free(nums);

    clock_t end = clock();
    double elapsed = (double)(end - start) / CLOCKS_PER_SEC;
    printf("\nExecution time: %f sec\n", elapsed);

    return 0;
}
