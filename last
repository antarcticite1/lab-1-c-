#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct humen {
    char name[50];
    char surname[50];
    int year;
};

int main() {
    struct humen *a;
    struct humen *b;
    int n = 0;
    int i, j;
    struct humen tmp;
    FILE *file;
    char line[200];

    file = fopen("data.txt", "r");
    if (file == NULL) {
        printf("Error: cannot open data.txt\n");
        return 1;
    }

    while (fgets(line, sizeof(line), file)) {
        n++;
    }
    fclose(file);

    a = (struct humen *)malloc(n * sizeof(struct humen));
    b = (struct humen *)malloc(n * sizeof(struct humen));

    if (a == NULL || b == NULL) {
        printf("Error: memory allocation failed\n");
        return 1;
    }

    file = fopen("data.txt", "r");
    for (i = 0; i < n; i++) {
        fscanf(file, "%s %s %d", a[i].name, a[i].surname, &a[i].year);
    }
    fclose(file);

    for (i = 0; i < n; i++) {
        b[i] = a[i];
    }

    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - 1 - i; j++) {
            if (b[j].year > b[j + 1].year) {
                tmp = b[j];
                b[j] = b[j + 1];
                b[j + 1] = tmp;
            }
        }
    }

    printf("\nSorted by year:\n");
    for (i = 0; i < n; i++) {
        printf("%s %s %d\n", b[i].name, b[i].surname, b[i].year);
    }

    printf("\nOnly Petrovich:\n");
    for (i = 0; i < n; i++) {
        if (strcmp(a[i].surname, "Petrovich") == 0) {
            printf("%s %s %d\n", a[i].name, a[i].surname, a[i].year);
        }
    }

    free(a);
    free(b);
    return 0;
} 
